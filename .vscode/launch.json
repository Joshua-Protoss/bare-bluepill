{
  "configurations": [

    {
      "name": "Debug app with openocd",
      "cwd": "${workspaceFolder}/app",
      "executable": "./firmware.elf",
      "servertype": "openocd",
      "request": "launch",
      "type": "cortex-debug",
      "device": "STM32F103C8T6",
      "runToEntryPoint": "main",
      "interface": "swd",
      "configFiles": [
        "interface/stlink.cfg",
        "target/stm32f1x.cfg"
      ]
    }
  ]
}